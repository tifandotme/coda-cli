          Python 3.13,python,import requests

headers = {'Authorization': 'Bearer <your API token>'}

# Delete all content from the page
uri = f'https://coda.io/apis/v1/docs/<doc ID>/pages/<page ID>/content'
req = requests.delete(uri, headers=headers)
req.raise_for_status()
res = req.json()
print(f'Deleted all content from page {res["id"]}')
# => Deleted all content from page <page ID>

# Delete specific elements
payload = {'elementIds': ['cl-abc123', 'cl-def456']}
req = requests.delete(uri, headers=headers, json=payload)
req.raise_for_status()
res = req.json()
print(f'Deleted {len(payload["elementIds"])} elements from page {res["id"]}')
# => Deleted 2 elements from page <page ID>

