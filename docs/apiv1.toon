var body = {
  row: {
    cells: [
      {'column': '<column ID>', 'value': 'Get groceries from Whole Foods'},
    ],
  },
};
var row = CodaAPI.updateRow('<doc ID>', '<table ID>', '<row ID>', body);
Logger.log('Updated row ' + row.id);
// => Updated row <row ID>

