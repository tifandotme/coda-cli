    PageCreateContent:
      x-schema-name: PageCreateContent
      description: Content that can be added to a page at creation time, either text (or rich text) or a URL to create a full-page embed.
      discriminator:
        propertyName: type
      oneOf: items[3]:
          - type: object
          required: items[2]:
              - type
